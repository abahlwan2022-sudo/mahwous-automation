# ─── Mahwous Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# On Railway: add these in the Variables section of your project.

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Your Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPTIONAL (Image Search) ────────────────────────────────────────────────────
# Google Custom Search API key from https://console.cloud.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Google Custom Search Engine ID from https://programmablesearchengine.google.com
# Configure it to search the entire web with image search enabled.
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# ── RUNTIME ────────────────────────────────────────────────────────────────────
# Port (Railway sets this automatically)
PORT=8080
